# Google AI Studio API key (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=AIza...

# Google Gemini model (default: gemini-2.0-flash)
GOOGLE_MODEL=gemini-2.0-flash

# MCP server (Ticket Management System Next.js app)
MCP_SERVER_URL=http://localhost:3000/api/mcp

# Port this agent server listens on
AGENT_SERVER_PORT=8000

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Session lifecycle (in-process memory store)
# Seconds of inactivity before a session is expired (default: 30 min)
IDLE_TIMEOUT_SECONDS=1800
# How often the background eviction sweep runs in seconds (default: 5 min)
SESSION_SWEEP_INTERVAL_SECONDS=300
# Hard cap on concurrent in-memory sessions (oldest evicted first when exceeded)
MAX_SESSIONS=1000
